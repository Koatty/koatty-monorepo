{
  "name": "koatty_testing",
  "version": "1.0.0",
  "description": "Testing utilities for Koatty applications.",
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:dts && pnpm run build:cp",
    "build:js": "tsup",
    "build:dts": "bash ../../scripts/build-dts.sh",
    "build:cp": "node ../../scripts/postBuild.js",
    "clean": "rimraf dist temp docs/api",
    "lint": "eslint --ext .ts,.js ./src",
    "test": "pnpm run lint && jest --passWithNoTests",
    "test:cov": "jest --collectCoverage --detectOpenHandles"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koatty/koatty_testing.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": {
    "name": "richenlin",
    "email": "richenlin@gmail.com"
  },
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/koatty/koatty_testing/issues"
  },
  "homepage": "https://github.com/koatty/koatty_testing",
  "maintainers": [
    {
      "name": "richenlin",
      "email": "richenlin@gmail.com"
    }
  ],
  "devDependencies": {
    "@microsoft/api-documenter": "^7.26.x",
    "@microsoft/api-extractor": "^7.52.x",
    "@types/jest": "^29.5.x",
    "@types/node": "^22.x.x",
    "@types/supertest": "^6.0.x",
    "@typescript-eslint/eslint-plugin": "^8.x.x",
    "@typescript-eslint/parser": "^8.x.x",
    "eslint": "^8.x.x",
    "eslint-plugin-jest": "^28.x.x",
    "jest": "^29.x.x",
    "jest-html-reporters": "^3.x.x",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.0.x",
    "ts-jest": "^29.x.x",
    "tslib": "^2.x.x"
  },
  "dependencies": {
    "koatty_container": "workspace:*",
    "koatty_core": "workspace:*",
    "koatty_lib": "workspace:*"
  },
  "peerDependencies": {
    "koatty_container": "^2.0.8",
    "koatty_core": "^2.0.8",
    "koatty_lib": "^1.4.8",
    "supertest": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "supertest": {
      "optional": false
    }
  },
  "types": "./dist/index.d.ts"
}
